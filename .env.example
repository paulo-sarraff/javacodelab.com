# =============================================================================
# JavaCodeLab — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no repositório
# =============================================================================

# -----------------------------------------------------------------------------
# NEWSLETTER — MailerLite
# Crie sua conta em: https://www.mailerlite.com
# API Key: https://app.mailerlite.com/integrations/api/
# Group ID: seção "Subscribers > Groups" no painel MailerLite
# -----------------------------------------------------------------------------
MAILERLITE_API_KEY=your_mailerlite_api_key_here
MAILERLITE_GROUP_ID=your_mailerlite_group_id_here   # Opcional — se não informado, usa o grupo padrão

# -----------------------------------------------------------------------------
# EMAIL DE CONTATO — Titan Email (SMTP)
# Configure em: https://titan.email
# Use o email e senha da sua conta Titan associada ao domínio
# -----------------------------------------------------------------------------
EMAIL_USER=contato@javacodelab.com
EMAIL_PASS=your_titan_email_password_here

# -----------------------------------------------------------------------------
# AMBIENTE
# Valores: development | production
# Em produção (Vercel), este valor é definido automaticamente
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# BASE URL
# Em desenvolvimento: http://localhost:3000
# Em produção: https://javacodelab.com
# Usado para gerar links absolutos (OG images, sitemap, etc.)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =============================================================================
# FASE 2 — Monetização (Clerk + Stripe + Neon)
# =============================================================================

# -----------------------------------------------------------------------------
# AUTENTICAÇÃO — Clerk (https://clerk.com)
# Crie seu app em: https://dashboard.clerk.com
# Publishable Key e Secret Key: seção "API Keys" do projeto
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/entrar
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/cadastro
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -----------------------------------------------------------------------------
# PAGAMENTOS — Stripe (https://stripe.com)
# Secret Key e Publishable Key: https://dashboard.stripe.com/apikeys
# Webhook Secret: crie um webhook em https://dashboard.stripe.com/webhooks
#   apontando para: https://seudominio.com/api/webhooks/stripe
#   Eventos necessários: checkout.session.completed,
#     customer.subscription.updated, customer.subscription.deleted,
#     invoice.payment_failed
# Preços: crie em https://dashboard.stripe.com/products
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs de preço dos planos premium
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
STRIPE_PRICE_LIFETIME=price_...

# -----------------------------------------------------------------------------
# BANCO DE DADOS — Neon PostgreSQL (https://neon.tech)
# Crie um projeto em neon.tech e copie as connection strings
# DATABASE_URL     → connection pooler (para a aplicação / Prisma Client)
# DIRECT_URL       → direct connection (para prisma migrate / db push)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx.pooler.neon.tech/dbname?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# =============================================================================
# FASE 3 — Analytics (GA4 + PostHog)
# =============================================================================

# -----------------------------------------------------------------------------
# GOOGLE ANALYTICS 4
# Crie uma propriedade GA4 em: https://analytics.google.com
# Measurement ID: Admin > Data Streams > Web stream > Measurement ID
# Formato: G-XXXXXXXXXX
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# POSTHOG — Analytics de produto (pageviews, funnels, session replay)
# Crie sua conta em: https://posthog.com (plano free: 1M eventos/mês)
# Project API Key: Project Settings > Project API Key
# Host: use o padrão abaixo ou o host da sua instância self-hosted
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
