# =============================================================================
# JavaCodeLab — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no repositório
# =============================================================================

# -----------------------------------------------------------------------------
# NEWSLETTER — MailerLite
# Crie sua conta em: https://www.mailerlite.com
# API Key: https://app.mailerlite.com/integrations/api/
# Group ID: seção "Subscribers > Groups" no painel MailerLite
# -----------------------------------------------------------------------------
MAILERLITE_API_KEY=your_mailerlite_api_key_here
MAILERLITE_GROUP_ID=your_mailerlite_group_id_here   # Opcional — se não informado, usa o grupo padrão

# -----------------------------------------------------------------------------
# EMAIL DE CONTATO — Titan Email (SMTP)
# Configure em: https://titan.email
# Use o email e senha da sua conta Titan associada ao domínio
# -----------------------------------------------------------------------------
EMAIL_USER=contato@javacodelab.com
EMAIL_PASS=your_titan_email_password_here

# -----------------------------------------------------------------------------
# AMBIENTE
# Valores: development | production
# Em produção (Vercel), este valor é definido automaticamente
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# BASE URL
# Em desenvolvimento: http://localhost:3000
# Em produção: https://javacodelab.com
# Usado para gerar links absolutos (OG images, sitemap, etc.)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =============================================================================
# PRÓXIMAS VARIÁVEIS (Fase 2 — Monetização)
# =============================================================================

# Autenticação — Clerk (https://clerk.com)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/entrar
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/cadastro

# Pagamentos — Stripe (https://stripe.com)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Banco de Dados — Neon PostgreSQL (https://neon.tech)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# =============================================================================
# PRÓXIMAS VARIÁVEIS (Fase 3 — Analytics)
# =============================================================================

# Google Analytics 4
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog (analytics de produto)
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
